# Скопируйте этот файл в .env и укажите реальные ключи API.
# Имена переменных должны совпадать с полем api_id в таблице models.

# OpenRouter — единый ключ для нескольких моделей (рекомендуется)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Прямые API (опционально)
OPENAI_API_KEY=sk-your-openai-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
GROQ_API_KEY=gsk-your-groq-key
