# ChatList — скопируйте этот файл в .env и укажите ключ OpenRouter.
# Получить ключ: https://openrouter.ai/keys
#
# Достаточно одной переменной — все модели в программе используют OpenRouter.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Бесплатные модели в программе (в API указываются С суффиксом :free):
#   google/gemma-4-31b-it:free          — Google (Gemma)
#   meta-llama/llama-3.3-70b-instruct:free
#   openai/gpt-oss-20b:free
#
# Суффикс :free обязателен — без него OpenRouter выберет платную версию модели.
# Актуальный список free-моделей: https://openrouter.ai/models?fmt=cards&filters=free
